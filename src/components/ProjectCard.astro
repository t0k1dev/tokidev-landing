---
interface Props {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  tech: string[];
  color: string;
}

const { id, title, subtitle, description, tech, color } = Astro.props;

// Split subtitle for the 2-line layout if it contains "problem solving"
const subtitleParts = subtitle.split('problem solving');
const hasProblemSolving = subtitle.includes('problem solving');
---

<div class="relative w-[1180px] h-[580px] rounded-[24px] border border-brand-border/10 group">
  <!-- Secondary Glass Background Layer (from Figma 6:935) -->
  <div class="absolute -inset-x-px -inset-y-px bg-linear-to-br from-black/36 to-zinc-400/5 backdrop-blur-[15px] rounded-[32px] -z-10"></div>
  
  <!-- Primary Background -->
  <div class="absolute inset-0 bg-brand-glass/60 backdrop-blur-[10px] rounded-[24px] -z-20"></div>
  
  <!-- Content Container: left: 89px, top: 123px -->
  <div class="absolute left-[89px] top-[123px] w-[600px] flex flex-col items-start z-10">
    <p class="font-bold text-[14px] text-brand-text/30 whitespace-nowrap mb-[12px]">
      {id}
    </p>
    
    <div class="bg-brand-purple/15 border border-brand-purple/20 px-[14px] py-[6px] rounded-full mb-[20px]">
      <p class="text-brand-purple text-[11px] font-bold tracking-[0.44px] uppercase whitespace-nowrap">
        Selected Projects
      </p>
    </div>

    <h3 class="text-[40px] font-bold tracking-[-0.8px] text-brand-text/95 leading-[48px] mb-[20px]">
      <span style={`color: ${color};`}>{title}</span>: {subtitleParts[0]}
      {hasProblemSolving && <br />}
      {hasProblemSolving && "problem solving"}
    </h3>

    <div class="text-brand-text/40 text-[14px] font-medium leading-[24px] mb-[24px] max-w-[480px]">
      <p>{description}</p>
    </div>

    <div class="flex gap-[8px] items-start">
      {tech.map((t) => (
        <div class="bg-brand-orange/8 border border-brand-orange/15 px-[14px] py-[6px] rounded-[6px]">
          <span class="text-[11px] font-bold text-brand-orange/80 tracking-[0.44px] uppercase whitespace-nowrap">
            {t}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- Visual Mockup Area: Bar Chart (from Figma screenshot 6:896) -->
  <div class="absolute left-[659px] top-[49px] w-[480px] h-[480px]">
      <!-- Central Glow -->
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[280px] h-[280px] bg-brand-purple/30 blur-[80px] rounded-full opacity-60 group-hover:bg-brand-orange/30 transition-colors duration-1000"></div>
      
      <!-- Mockup Card Wrapper -->
      <div class="absolute left-[30px] top-[30px] w-[420px] h-[420px] bg-linear-to-br from-[#1a1029] to-[#0f0a1a] border border-white/10 rounded-[28px] shadow-2xl overflow-hidden group-hover:scale-[1.02] transition-transform duration-700">
          
          <!-- Inner Glow -->
          <div class="absolute left-[40%] top-[40%] w-[200px] h-[200px] bg-brand-orange/15 blur-[60px] rounded-full"></div>

          <!-- Decorative Lines/Grid -->
          <div class="absolute inset-0 p-10 flex flex-col justify-between opacity-10">
              {[1,2,3,4,5,6].map(() => (
                  <div class="w-full h-px bg-white/40"></div>
              ))}
          </div>

          <!-- Bar Chart Visual -->
          <div class="absolute inset-0 flex items-end justify-center gap-4 px-12 pb-16">
              {[35, 65, 45, 90, 55, 75, 40, 50].map((h, i) => (
                  <div 
                    class="w-full bg-linear-to-t from-brand-orange/40 to-brand-orange/10 rounded-t-sm transition-all duration-1000 group-hover:from-brand-purple/40 group-hover:to-brand-purple/10" 
                    style={`height: ${h}px; transition-delay: ${i * 50}ms;`}
                  ></div>
              ))}
          </div>

          <!-- Overlay Shine -->
          <div class="absolute inset-0 bg-linear-to-tr from-white/5 to-transparent pointer-events-none"></div>
      </div>
  </div>
</div>
