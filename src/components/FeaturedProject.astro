---
import ProjectCard from './ProjectCard.astro';

const featuredProject = {
  id: "01",
  title: "solveOS",
  subtitle: "distributed problem solving",
  description: "A distributed operating system framework for real-time problem solving. Built with Rust and WebAssembly to enable high-performance compute in browser environments.",
  tech: ["RUST", "WASM", "REDIS"],
  color: "#ef6c4a"
};
---

<section id="projects" class="w-full max-w-[1440px] mx-auto relative pt-12 md:pt-[140px] pb-24 md:pb-32 px-4 md:px-0">
  <!-- Section Label -->
  <div class="relative md:absolute top-0 md:top-[57px] left-0 md:left-[86px] flex items-center gap-[12px] mb-8 md:mb-0">
    <div class="bg-brand-orange/80 h-[2px] w-[32px]"></div>
    <span class="text-brand-orange/70 text-[14px] md:text-[16px] font-bold tracking-[1.92px] whitespace-nowrap">
      SELECTED PROJECTS
    </span>
  </div>

  <!-- Project Card -->
  <div class="w-full flex justify-center mt-0">
    <ProjectCard {...featuredProject} />
  </div>
</section>
