---
interface Props {
  company: string;
  role: string;
  period: string;
  description: string;
  color: string;
  isCurrent?: boolean;
}

const { company, role, period, description, color, isCurrent = false } = Astro.props;
---

<div class={`relative flex flex-col items-center pt-10 md:pt-12 px-6 md:px-8 h-auto md:h-[520px] rounded-[24px] border border-solid overflow-hidden group transition-all duration-500 hover:scale-[1.02] pb-10 md:pb-0`} 
     style={`border-color: ${color}1f;`}>
  
  <!-- Glass Background -->
  <div class="absolute inset-0 bg-linear-to-br from-black/35 to-white/5 backdrop-blur-xl -z-10"></div>
  
  <!-- Period and Badge -->
  <div class="flex items-center gap-2.5 mb-4 z-10">
    <span class="text-[10px] md:text-[11px] font-medium text-brand-text/30 tracking-[0.66px] uppercase">
      {period}
    </span>
    {isCurrent && (
      <div class="px-2 py-1 bg-brand-orange/15 rounded-md border border-brand-orange/20">
        <span class="text-[9px] font-bold text-brand-orange tracking-[0.72px]">CURRENT</span>
      </div>
    )}
  </div>

  <!-- Role and Company -->
  <div class="text-center z-10 mb-4 px-2">
    <h3 class="text-[28px] md:text-[32px] font-bold leading-[1.2] tracking-[-0.64px] text-white/95">
      {role} <br class="hidden md:block" /> {role.includes('Software') ? '' : 'at'} <br class="hidden md:block" />
      <span style={`color: ${color};`}>{company}</span>
    </h3>
  </div>

  <!-- Description -->
  <p class="text-[14px] md:text-[13px] font-medium text-center text-brand-text/35 leading-normal max-w-[280px] z-10 mb-8 md:mb-0">
    {description}
  </p>

  <div class="hidden md:block grow"></div>

  <!-- Glow Effect at bottom -->
  <div class="relative w-full h-[120px] md:h-[180px] -mb-10 opacity-60 group-hover:opacity-100 transition-opacity duration-700 mt-auto">
    <div class="absolute left-1/2 -translate-x-1/2 top-0 w-[200px] md:w-[280px] h-[200px] md:h-[280px] rounded-full blur-[60px] md:blur-[80px]" 
         style={`background: ${color}33;`}></div>
    <div class="absolute left-1/2 -translate-x-1/2 top-10 w-[100px] md:w-[140px] h-[100px] md:h-[140px] rounded-full blur-2xl" 
         style={`background: ${color}66;`}></div>
  </div>
</div>
